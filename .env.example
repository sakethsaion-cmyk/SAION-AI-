# ── Firebase Configuration ────────────────────────────────────────────────────
# Get from Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
# Get from openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Backend URL (your Render backend) ────────────────────────────────────────
VITE_BACKEND_URL=https://saion-ai.onrender.com

# ── Image Generation (optional — Pollinations.ai is free fallback) ────────────
# HuggingFace: https://huggingface.co/settings/tokens
VITE_HF_TOKEN=your_huggingface_token_here
# fal.ai: https://fal.ai/dashboard/keys
VITE_FAL_KEY=your_fal_ai_key_here

# ── Stripe (optional — for subscriptions) ────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key_here
