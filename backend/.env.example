# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Netlify Deploy (for website builder feature) ──────────────────────────────
# Get from: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_ACCESS_TOKEN=your_netlify_token_here

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" first. BACKEND ONLY — never expose to frontend.
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Cache TTL (optional) ─────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
